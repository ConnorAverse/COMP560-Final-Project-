# Copy to .env and fill in your keys

# OpenAI / ChatGPT
OPENAI_API_KEY=sk-...

# Google Gemini
GEMINI_API_KEY=AIza...

# Deepseek (OpenAI-compatible API)
DEEPSEEK_API_KEY=sk-...

# US Census Bureau API (free at api.census.gov/data/key_signup.html)
CENSUS_API_KEY=

# --- Scraper config ---
# How many jobs to pull per search term per source
JOBS_PER_TERM=5

# Search terms (comma-separated)
SEARCH_TERMS=software engineer,registered nurse,financial analyst,marketing manager,construction manager,data scientist,elementary school teacher,mechanical engineer,human resources manager,lawyer

# Default location filter
LOCATION=United States

# Playwright: set to "true" to run browser headless (recommended for CI)
HEADLESS=true

# People to generate per job per AI model (100 recommended, reduce for testing)
PEOPLE_PER_JOB=100
